  "inkbo": {
    "name": "Inkbo",
    "slug": "inkbo",
    "seo": {
      "title": "Inkbo (Boix) — Anime, Cartoon e Ilustración Digital | Von Bastik",
      "description": "Inkbo (Boix) transforma conceptos en piezas únicas bajo un estilo Cartoon sofisticado. Dominio del volumen y color autodidacta en Alcalá de Henares.",
